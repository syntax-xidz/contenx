tunnel_show_groups() {
    local svc="$1"
    local page="$2"
    local chat_id="$3"
    local list_file="/tmp/xidz_tg_${chat_id}.txt"
    
    if [ "$page" -eq 1 ]; then
        tunnel_api_call "$svc" "/proxies" | jq -r '.proxies | to_entries[] | select(.value.type=="Selector" or .value.type=="Fallback" or .value.type=="URLTest") | .key' > "$list_file"
    fi
    
    if [ ! -s "$list_file" ]; then
        local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back\",\"callback_data\":\"tunnel_dash_${svc}\"}]]"
        send_keyboard_menu "✘ No Proxy Groups found." "$chat_id" "$kb"
        return
    fi
    
    local total=$(wc -l < "$list_file")
    local limit=9
    local total_pages=$(( (total + limit - 1) / limit ))
    [ "$total_pages" -eq 0 ] && total_pages=1
    [ "$page" -lt 1 ] && page=1
    [ "$page" -gt "$total_pages" ] && page="$total_pages"
    
    local start=$(( (page - 1) * limit + 1 ))
    local end=$(( page * limit ))
    
    local kb="["
    local row="["
    local col=0
    local i=$start
    while [ $i -le $end ] && [ $i -le $total ]; do
        local gname=$(sed -n "${i}p" "$list_file")
        local safe_name=$(escape_html "$gname")
        [ $col -gt 0 ] && row="${row},"
        row="${row}{\"text\":\"${safe_name}\",\"callback_data\":\"t_g_${svc}_${i}\"}"
        col=$((col + 1))
        if [ $col -eq 3 ]; then
            kb="${kb}${row}],"
            row="["
            col=0
        fi
        i=$((i + 1))
    done
    if [ $col -gt 0 ]; then kb="${kb}${row}],"; fi
    
    local nav="["
    if [ "$page" -gt 1 ]; then
        nav="${nav}{\"text\":\"⬅ Prev\",\"callback_data\":\"t_pg_${svc}_$((page - 1))\"},"
    fi
    nav="${nav}{\"text\":\"$page / $total_pages\",\"callback_data\":\"ignore\"}"
    if [ "$page" -lt "$total_pages" ]; then
        nav="${nav},{\"text\":\"Next ➔\",\"callback_data\":\"t_pg_${svc}_$((page + 1))\"}"
    fi
    nav="${nav}]"
    kb="${kb}${nav},[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back to Dashboard\",\"callback_data\":\"tunnel_dash_${svc}\"}]]"
    
    send_keyboard_menu "🔀 <b>Proxy Groups ($svc)</b>\nSelect a group to configure:" "$chat_id" "$kb"
}
tunnel_show_proxies() {
    local svc="$1"
    local g_idx="$2"
    local page="$3"
    local chat_id="$4"
    local group_list="/tmp/xidz_tg_${chat_id}.txt"
    local proxy_list="/tmp/xidz_tp_${chat_id}.txt"
    local cur_group_file="/tmp/xidz_cg_${chat_id}.txt"
    
    local gname=""
    if [ -n "$g_idx" ]; then
        gname=$(sed -n "${g_idx}p" "$group_list")
        echo "$gname" > "$cur_group_file"
        local json=$(tunnel_api_call "$svc" "/proxies")
        echo "$json" | jq -r --arg g "$gname" '.proxies[$g].all[]?' > "$proxy_list"
    else
        gname=$(cat "$cur_group_file")
    fi
    
    local current_proxy=$(tunnel_api_call "$svc" "/proxies" | jq -r --arg g "$gname" '.proxies[$g].now?')
    
    local total=$(wc -l < "$proxy_list")
    local limit=9
    local total_pages=$(( (total + limit - 1) / limit ))
    [ "$total_pages" -eq 0 ] && total_pages=1
    [ "$page" -lt 1 ] && page=1
    [ "$page" -gt "$total_pages" ] && page="$total_pages"
    
    local start=$(( (page - 1) * limit + 1 ))
    local end=$(( page * limit ))
    
    local kb="["
    local row="["
    local col=0
    local i=$start
    while [ $i -le $end ] && [ $i -le $total ]; do
        local pname=$(sed -n "${i}p" "$proxy_list")
        local mark=""
        [ "$pname" = "$current_proxy" ] && mark="✔ "
        local safe_name=$(escape_html "${mark}${pname}")
        
        [ $col -gt 0 ] && row="${row},"
        row="${row}{\"text\":\"${safe_name}\",\"callback_data\":\"t_s_${svc}_${i}_${page}\"}"
        col=$((col + 1))
        if [ $col -eq 3 ]; then
            kb="${kb}${row}],"
            row="["
            col=0
        fi
        i=$((i + 1))
    done
    if [ $col -gt 0 ]; then kb="${kb}${row}],"; fi
    
    local nav="["
    if [ "$page" -gt 1 ]; then
        nav="${nav}{\"text\":\"⬅ Prev\",\"callback_data\":\"t_pp_${svc}_$((page - 1))\"},"
    fi
    nav="${nav}{\"text\":\"$page / $total_pages\",\"callback_data\":\"ignore\"}"
    if [ "$page" -lt "$total_pages" ]; then
        nav="${nav},{\"text\":\"Next ➔\",\"callback_data\":\"t_pp_${svc}_$((page + 1))\"}"
    fi
    nav="${nav}]"
    kb="${kb}${nav},[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back to Groups\",\"callback_data\":\"t_pg_${svc}_1\"}]]"
    
    local safe_gname=$(escape_html "$gname")
    send_keyboard_menu "🌐 <b>Group: ${safe_gname}</b>\nCurrent: <code>${current_proxy}</code>\nSelect proxy:" "$chat_id" "$kb"
}
tunnel_set_proxy() {
    local svc="$1"
    local p_idx="$2"
    local page="$3"
    local chat_id="$4"
    local cur_group_file="/tmp/xidz_cg_${chat_id}.txt"
    local proxy_list="/tmp/xidz_tp_${chat_id}.txt"
    
    local gname=$(cat "$cur_group_file")
    local pname=$(sed -n "${p_idx}p" "$proxy_list")
    
    local payload=$(jq -n --arg name "$pname" '{name: $name}')
    local gname_url=$(jq -nr --arg v "$gname" '$v|@uri')
    
    tunnel_api_call "$svc" "/proxies/${gname_url}" "PUT" "$payload"
    sleep 0.1
    
    tunnel_show_proxies "$svc" "" "$page" "$chat_id"
}
