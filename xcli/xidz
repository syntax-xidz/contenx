del_cron_menu() {
    local chat_id="$1"
    if [ ! -s /etc/crontabs/root ]; then
        local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back\",\"callback_data\":\"cron_menu\"}]]"
        send_keyboard_menu "✘ No crons saved." "$chat_id" "$kb"
        return
    fi
    local kb="["
    local n=1
    local col_count=0
    local row="["
    local msg="Saved Crons:\n"
    while read -r line; do
        [ -z "$line" ] && continue
        local short_line="${line:0:25}"
        msg="${msg}${n}. ${short_line}...\n"
        [ $col_count -gt 0 ] && row="${row},"
        row="${row}{\"text\":\"✘ Delete $n\",\"callback_data\":\"rmc_${n}\"}"
        col_count=$((col_count+1))
        n=$((n+1))
        if [ $col_count -eq 3 ]; then
            kb="${kb}${row}],"
            row="["
            col_count=0
        fi
    done < /etc/crontabs/root
    if [ $col_count -gt 0 ]; then kb="${kb}${row}],"; fi
    kb="${kb}[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back\",\"callback_data\":\"cron_menu\"}]]"
    msg=$(escape_html "$msg")
    send_keyboard_menu "$msg\nSelect cron to delete:" "$chat_id" "$kb"
}
