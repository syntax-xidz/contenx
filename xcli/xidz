get_uci_interface_name() {
    local phy="$1"
    local uci_name=$(uci show network 2>/dev/null | grep -w "device='$phy'" | head -1 | cut -d'.' -f2 | cut -d'.' -f1)
    [ -z "$uci_name" ] && uci_name=$(uci show network 2>/dev/null | grep -w "ifname='$phy'" | head -1 | cut -d'.' -f2 | cut -d'.' -f1)
    [ -z "$uci_name" ] && uci_name=$(uci show network 2>/dev/null | grep -w "proto='qmi'" | head -1 | cut -d'.' -f2 | cut -d'.' -f1)
    if [ -z "$uci_name" ]; then case "$phy" in usb*) echo "wwan";; eth*) echo "wan";; wwan*) echo "wwan";; *) echo "$phy";; esac; else echo "$uci_name"; fi
}
get_interface_status() {
    local iface="$1"
    local ip=$(ip addr show $iface 2>/dev/null | grep "inet " | awk '{print $2}' | cut -d'/' -f1 | head -1 || echo "No IP")
    local state=$(cat /sys/class/net/$iface/operstate 2>/dev/null || echo "unknown")
    local carrier=$(cat /sys/class/net/$iface/carrier 2>/dev/null || echo "0")
    local status="✘ Down"
    if [ "$state" = "up" ] && [ "$carrier" = "1" ]; then status="✔ Up"; elif [ "$state" = "up" ]; then status="✘ No Carrier"; fi
    
    local rx_bytes=$(cat /sys/class/net/$iface/statistics/rx_bytes 2>/dev/null || echo 0)
    local tx_bytes=$(cat /sys/class/net/$iface/statistics/tx_bytes 2>/dev/null || echo 0)
    local total_bytes=$((rx_bytes + tx_bytes))
    local usage="0 MB"
    if [ "$total_bytes" -gt 1073741824 ]; then
        usage=$(awk "BEGIN {printf \"%.2f GB\", $total_bytes/1073741824}")
    else
        usage=$(awk "BEGIN {printf \"%.2f MB\", $total_bytes/1048576}")
    fi
    
    local uci_name=$(get_uci_interface_name "$iface")
    local up_sec=$(ubus call network.interface.$uci_name status 2>/dev/null | grep '"uptime"' | grep -o '[0-9]*')
    local up_str="N/A"
    if [ -n "$up_sec" ] && [ "$up_sec" -gt 0 ]; then
        local d=$((up_sec/86400))
        local h=$((up_sec%86400/3600))
        local m=$((up_sec%3600/60))
        local s=$((up_sec%60))
        if [ $d -gt 0 ]; then up_str="${d}d ${h}h ${m}m"; else up_str="${h}h ${m}m ${s}s"; fi
    fi
    
    echo "${ip}|${status}|${usage}|${up_str}"
}
