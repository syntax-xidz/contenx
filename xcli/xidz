        return
    fi
    local kb="["
    local col_count=0
    local row="["
    local current=$(uci get luci.main.mediaurlbase 2>/dev/null)
    for t in $themes; do
        local t_path=$(uci -q get luci.themes.$t)
        local mark=""
        [ "$t_path" = "$current" ] && mark="✔ "
