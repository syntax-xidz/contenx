handle_command_or_file() {
    local chat_id="$1"
    local text="$2"
    local file_id="$3"
    local file_name="$4"
    local command="$text"
    local thread_suffix=""; [ -n "$MESSAGE_THREAD_ID_CUR" ] && thread_suffix="_${MESSAGE_THREAD_ID_CUR}"
    local state_file="${STATE_FILE_PREFIX}${chat_id}${thread_suffix}"
    
    if [ -n "$BOT_USERNAME_CUR" ]; then
        if [[ "$command" == *"@${BOT_USERNAME_CUR}"* ]]; then
            command=$(echo "$command" | sed "s/@${BOT_USERNAME_CUR}//g" | xargs)
            [ -z "$command" ] && command="/menu"
        fi
    fi

    if [ -f "$state_file" ]; then
        local state=$(cat "$state_file")
        case "$state" in
            WAIT_TOOLS_UPLOAD_DIR)
                local dir=$(echo "$text" | xargs)
                rm -f "$state_file"
                delete_last_message "$chat_id"
                [ -z "$dir" ] && dir="/tmp"
                echo "WAIT_TOOLS_UPLOAD_FILE:${dir}|0|0|0" > "$state_file"
                local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Cancel\",\"callback_data\":\"tools_menu\"}]]"
                send_keyboard_menu "Directory Set: ${dir}\nNow send/upload your media/file(s) to this bot chat.\n(Multi-upload supported)" "$chat_id" "$kb"
                return
                ;;
            WAIT_TOOLS_UPLOAD_FILE:*)
                local state_data=${state#WAIT_TOOLS_UPLOAD_FILE:}
                local dir=$(echo "$state_data" | cut -d'|' -f1)
                local succ=$(echo "$state_data" | cut -d'|' -f2)
                local err=$(echo "$state_data" | cut -d'|' -f3)
                local tot=$(echo "$state_data" | cut -d'|' -f4)
                [ -z "$succ" ] && succ=0; [ -z "$err" ] && err=0; [ -z "$tot" ] && tot=0
                
                local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"✔ Done / Cancel\",\"callback_data\":\"tools_menu\"}]]"
                if [ -n "$file_id" ]; then
                    delete_last_message "$chat_id"
                    local file_info=$(curl $CURL_RESOLVE -s -X GET "${API_URL}/getFile?file_id=${file_id}")
                    local file_path=$(echo "$file_info" | grep -o '"file_path":"[^"]*"' | cut -d'"' -f4)
                    tot=$((tot + 1))
                    if [ -n "$file_path" ]; then
                        mkdir -p "$dir"
                        [ -z "$file_name" ] && file_name="file_$(date +%s%N)"
                        if wget -qO "${dir}/${file_name}" "https://api.telegram.org/file/bot${BOT_TOKEN_CUR}/${file_path}" 2>&1 || curl -s -o "${dir}/${file_name}" "https://api.telegram.org/file/bot${BOT_TOKEN_CUR}/${file_path}" 2>&1; then
                            succ=$((succ + 1))
                        else
                            err=$((err + 1))
                        fi
                    else
                        err=$((err + 1))
                    fi
                    echo "WAIT_TOOLS_UPLOAD_FILE:${dir}|${succ}|${err}|${tot}" > "$state_file"
                    
                    local ls_out=$(ls -1 "$dir" 2>/dev/null | head -n 15)
                    [ -z "$ls_out" ] && ls_out="Empty"
                    ls_out=$(escape_html "$ls_out")
                    
                    local msg="Succes Upload ${succ} File | Error ${err} | Total ${tot} File\n\n"
                    msg="${msg}<b>Folder Contents (${dir}):</b>\n<pre>${ls_out}</pre>\n\n<i>Send more files or press Done.</i>"
                    send_keyboard_menu "$msg" "$chat_id" "$kb"
                    return
                else
                    if [[ "$text" == /* ]]; then
                        rm -f "$state_file"
                    else
                        delete_last_message "$chat_id"
                        send_keyboard_menu "✘ Please send a file/image, or press Done.\nWaiting for upload to: ${dir}" "$chat_id" "$kb"
                        return
                    fi
                fi
                ;;
            WAIT_TOOLS_DL_DIR)
                local dir=$(echo "$text" | xargs)
                rm -f "$state_file"
                delete_last_message "$chat_id"
                [ -z "$dir" ] && dir="/tmp"
                echo "WAIT_TOOLS_DL_URL:${dir}" > "$state_file"
                local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"✔ Done / Cancel\",\"callback_data\":\"tools_menu\"}]]"
                send_keyboard_menu "Directory Set: ${dir}\nNow send URL(s) to download.\n(Multi-URL supported by separating with space or newline)" "$chat_id" "$kb"
                return
                ;;
            WAIT_TOOLS_DL_URL:*)
                local dir=${state#WAIT_TOOLS_DL_URL:}
                local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"✔ Done / Cancel\",\"callback_data\":\"tools_menu\"}]]"
                if [[ "$text" == /* ]]; then
                    rm -f "$state_file"
                else
                    delete_last_message "$chat_id"
                    mkdir -p "$dir"
                    local urls=$(echo "$text" | tr '\n' ' ')
                    local result_msg="Download Results:\n"
                    for url in $urls; do
                        if [[ "$url" =~ ^https?:// ]]; then
                            local fname=$(basename "$url" | cut -d? -f1)
                            [ -z "$fname" ] && fname="dl_$(date +%s)"
                            local out
                            if out=$(wget -qO "${dir}/${fname}" "$url" 2>&1 || curl -s -L -o "${dir}/${fname}" "$url" 2>&1); then
                                local escaped_fname=$(escape_html "$fname")
                                result_msg="${result_msg}✔ <code>${escaped_fname}</code>\n"
                            else
                                local escaped_fname=$(escape_html "$fname")
                                result_msg="${result_msg}✘ <code>${escaped_fname}</code> (Failed)\n"
                            fi
                        fi
                    done
                    send_keyboard_menu "${result_msg}\n<i>Send more URLs or press Done.</i>" "$chat_id" "$kb"
                    return
                fi
                ;;
            WAIT_TOOLS_EXTRACT_FILE)
                local filepath=$(echo "$text" | xargs)
                delete_last_message "$chat_id"
                if [ -f "$filepath" ]; then
                    echo "WAIT_TOOLS_EXTRACT_DIR:${filepath}" > "$state_file"
                    local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Cancel\",\"callback_data\":\"tools_menu\"}]]"
                    send_keyboard_menu "File found: $filepath\nSend destination directory to extract to (e.g. /tmp/ext):" "$chat_id" "$kb"
                else
                    local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back\",\"callback_data\":\"tools_menu\"}]]"
                    send_keyboard_menu "✘ File not found: $filepath" "$chat_id" "$kb"
                    rm -f "$state_file"
                fi
                return
                ;;
            WAIT_TOOLS_EXTRACT_DIR:*)
                local filepath=${state#WAIT_TOOLS_EXTRACT_DIR:}
                local dst=$(echo "$text" | xargs)
                rm -f "$state_file"
                delete_last_message "$chat_id"
                local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back\",\"callback_data\":\"tools_menu\"}]]"
                mkdir -p "$dst"
                local out
                local success=0
                case "$filepath" in
                    *.tar.bz2) out=$(tar -xjf "$filepath" -C "$dst" 2>&1) && success=1 ;;
                    *.tar.gz|*.tgz) out=$(tar -xzf "$filepath" -C "$dst" 2>&1) && success=1 ;;
                    *.tar) out=$(tar -xf "$filepath" -C "$dst" 2>&1) && success=1 ;;
                    *.zip) out=$(unzip -o "$filepath" -d "$dst" 2>&1) && success=1 ;;
                    *.gz) 
                        local fname=$(basename "$filepath" .gz)
                        out=$(gzip -dc "$filepath" > "${dst}/${fname}" 2>&1) && success=1 
                        ;;
                    *) out="Unsupported file extension. Only tar, tar.gz, tgz, tar.bz2, zip, gz are supported." ;;
                esac
                out=$(escape_html "$out")
                if [ "$success" -eq 1 ]; then
                    send_keyboard_menu "✔ Extraction Success to:\n<code>$dst</code>\n<pre>${out:0:3000}</pre>" "$chat_id" "$kb"
                else
                    send_keyboard_menu "✘ Extraction Failed:\n<pre>${out:0:3000}</pre>" "$chat_id" "$kb"
                fi
                return
                ;;
            WAIT_TOOLS_LUCI_PASS)
                rm -f "$state_file"
                delete_last_message "$chat_id"
                local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back\",\"callback_data\":\"tools_menu\"}]]"
                if [ -n "$text" ]; then
                    if command -v chpasswd >/dev/null 2>&1; then
                        echo "root:$text" | chpasswd
                    else
                        echo -e "$text\n$text" | passwd root
                    fi
                    echo "$text" > /etc/xidzs_luci_pass.txt
                    local escaped_pass=$(escape_html "$text")
                    send_keyboard_menu "✔ LuCI Password changed to:\n<pre>$escaped_pass</pre>" "$chat_id" "$kb"
                else
                    send_keyboard_menu "✘ Invalid password!" "$chat_id" "$kb"
                fi
                return
                ;;
            WAIT_TOOLS_CHANGE_IP)
                local ip=$(echo "$text" | xargs)
                rm -f "$state_file"
                delete_last_message "$chat_id"
                local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Cancel\",\"callback_data\":\"tools_menu\"}]]"
                if [[ "$ip" =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]]; then
                    uci set network.lan.ipaddr="$ip"
                    uci commit network
                    /etc/init.d/network restart >/dev/null 2>&1 &
                    send_keyboard_menu "✔ LAN IP changed to: <code>$ip</code>\nNetwork is restarting..." "$chat_id" "$kb"
                else
                    send_keyboard_menu "✘ Invalid IP Address format!" "$chat_id" "$kb"
                fi
                return
                ;;
            WAIT_EQOS_SPEED:*)
                local ip=${state#WAIT_EQOS_SPEED:}
                rm -f "$state_file"
                delete_last_message "$chat_id"
                local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back\",\"callback_data\":\"eqosplus_menu\"}]]"
                local up=$(echo "$text" | awk '{print $1}')
                local down=$(echo "$text" | awk '{print $2}')
                local tstart=$(echo "$text" | awk '{print $3}')
                local tend=$(echo "$text" | awk '{print $4}')
                local week=$(echo "$text" | awk '{print $5}')
                
                [ -z "$tstart" ] && tstart="00:00"
                [ -z "$tend" ] && tend="00:00"
                [ -z "$week" ] && week="0"

                if [[ "$up" =~ ^[0-9.]+$ ]] && [[ "$down" =~ ^[0-9.]+$ ]]; then
                    local exists=$(uci show eqosplus 2>/dev/null | grep -E "\.ip='$ip'|\.mac='$ip'" | cut -d. -f2 | cut -d= -f1)
                    for e in $exists; do uci delete eqosplus.$e 2>/dev/null; done
                    
                    uci add eqosplus device >/dev/null
                    uci set eqosplus.@device[-1].ip="$ip"
                    uci set eqosplus.@device[-1].mac="$ip"
                    uci set eqosplus.@device[-1].upload="$up"
                    uci set eqosplus.@device[-1].download="$down"
                    uci set eqosplus.@device[-1].timestart="$tstart"
                    uci set eqosplus.@device[-1].timeend="$tend"
                    uci set eqosplus.@device[-1].week="$week"
                    uci set eqosplus.@device[-1].enable="1"
                    uci commit eqosplus
                    sleep 1
                    /etc/init.d/eqosplus reload >/dev/null 2>&1 || /etc/init.d/eqosplus restart >/dev/null 2>&1
                    send_keyboard_menu "✔ EQoS Rule Added & Applied!\nIP/MAC: <code>${ip}</code>\nUpload: ${up} Mbps\nDownload: ${down} Mbps\nTime: ${tstart} - ${tend} (Week: ${week})" "$chat_id" "$kb"
                else
                    send_keyboard_menu "✘ Invalid format! Please use numbers (e.g. 5 10 00:00 00:00 0)." "$chat_id" "$kb"
                fi
                return
                ;;
            WAIT_TUNNEL_AUTH:*)
                local svc=${state#WAIT_TUNNEL_AUTH:}
                rm -f "$state_file"
                delete_last_message "$chat_id"
                echo "$text" > "/etc/xidzs_api_secret_${svc}.txt"
                local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Open Dashboard\",\"callback_data\":\"tunnel_dash_${svc}\"}]]"
                send_keyboard_menu "✔ API Auth Secret saved!\nTry opening the dashboard again." "$chat_id" "$kb"
                return
                ;;
            WAIT_PKG_DL_URL)
                local url=$(echo "$text" | xargs)
                rm -f "$state_file"
                delete_last_message "$chat_id"
                mkdir -p "$DEFAULT_DL_DIR"
                local fname=$(basename "$url" | cut -d? -f1)
                local dest="${DEFAULT_DL_DIR}/${fname}"
                local out
                local success=0
                if out=$(wget -qO "$dest" "$url" 2>&1 || curl -s -L -o "$dest" "$url" 2>&1); then
                    success=1
                fi
                out=$(escape_html "$out")
                if [ "$success" -eq 1 ]; then
                    echo "WAIT_PKG_CONFIRM:${dest}" > "$state_file"
                    local kb="[[{\"text\":\"✔ Install Now\",\"callback_data\":\"pkg_install_dl\"}],[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"✘ Cancel\",\"callback_data\":\"pkg_menu\"}]]"
                    send_keyboard_menu "✔ Download Success:\n<code>${fname}</code>\n\nDo you want to install it now?" "$chat_id" "$kb"
                else
                    local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back\",\"callback_data\":\"pkg_menu\"}]]"
                    send_keyboard_menu "✘ Download Error:\n<pre>${out:0:3000}</pre>" "$chat_id" "$kb"
                fi
                return
                ;;
            WAIT_WIFI_SEC_PASS:*)
                local state_data=${state#WAIT_WIFI_SEC_PASS:}
                local i=$(echo "$state_data" | cut -d'|' -f1)
                local val=$(echo "$state_data" | cut -d'|' -f2)
                rm -f "$state_file"
                delete_last_message "$chat_id"
                local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back\",\"callback_data\":\"w_se_sel\"}]]"
                if [ ${#text} -ge 8 ]; then
                    uci set wireless.@wifi-iface[$i].encryption="$val"
                    uci set wireless.@wifi-iface[$i].key="$text"
                    uci commit wireless
                    wifi reload >/dev/null 2>&1 &
                    local ssid=$(uci -q get wireless.@wifi-iface[$i].ssid)
                    local escaped_pass=$(escape_html "$text")
                    send_keyboard_menu "✔ Security for $ssid changed to: $val\n✔ Password set to: <pre>$escaped_pass</pre>\nApplying changes..." "$chat_id" "$kb"
                else
                    send_keyboard_menu "✘ Error: Password must be at least 8 characters!" "$chat_id" "$kb"
                fi
                return
                ;;
            WAIT_IFACE_ADD_NAME)
                local iname=$(echo "$text" | xargs | tr -cd 'a-zA-Z0-9_-')
                rm -f "$state_file"
                delete_last_message "$chat_id"
                local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Cancel\",\"callback_data\":\"interface\"}]]"
                if [ -n "$iname" ]; then
                    echo "$iname" > "/tmp/xidz_iface_add_${chat_id}.txt"
                    local p_kb="[[{\"text\":\"DHCP Client\",\"callback_data\":\"i_add_p_dhcp\"},{\"text\":\"Static IP\",\"callback_data\":\"i_add_p_static\"}],[{\"text\":\"PPPoE\",\"callback_data\":\"i_add_p_pppoe\"},{\"text\":\"QMI Cellular\",\"callback_data\":\"i_add_p_qmi\"}],[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Cancel\",\"callback_data\":\"interface\"}]]"
                    send_keyboard_menu "Interface: <b>$iname</b>\n\nSelect Protocol:" "$chat_id" "$p_kb"
                else
                    send_keyboard_menu "✘ Invalid interface name!" "$chat_id" "$kb"
                fi
                return
                ;;
            WAIT_TOOLS_CHMOD)
                rm -f "$state_file"
                delete_last_message "$chat_id"
                local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back\",\"callback_data\":\"tools_menu\"}]]"
                local perms=$(echo "$text" | awk '{print $1}')
                local path=$(echo "$text" | awk '{print $2}')
                if [[ "$perms" =~ ^[0-7]{3,4}$ ]] && [ -e "$path" ]; then
                    local out
                    if out=$(chmod "$perms" "$path" 2>&1); then
                        send_keyboard_menu "✔ Success Set Permission:\n<code>chmod $perms $path</code>" "$chat_id" "$kb"
                    else
                        out=$(escape_html "$out")
                        send_keyboard_menu "✘ Error Set Permission:\n<pre>$out</pre>" "$chat_id" "$kb"
                    fi
                else
                    send_keyboard_menu "✘ Invalid Input Format or File Path Not Found!\n\nEnsure mode is octal (e.g., 755) and target exists." "$chat_id" "$kb"
                fi
                return
                ;;
        esac
    fi
    case "$command" in
        /start|/menu) delete_last_message "$chat_id"; show_main_menu "$chat_id" ;;
        /status) delete_last_message "$chat_id"; get_system_status "$chat_id" ;;
        /clear) delete_last_message "$chat_id"; clear_memory "$chat_id" ;;
        /packages) delete_last_message "$chat_id"; show_pkg_menu "$chat_id" ;;
        /tools) delete_last_message "$chat_id"; show_tools_menu "$chat_id" ;;
        /vnstat) delete_last_message "$chat_id"; show_vnstat_menu "$chat_id" ;;
        /wifi) delete_last_message "$chat_id"; show_wifi_menu "$chat_id" ;;
        /tailscale) delete_last_message "$chat_id"; show_remote_menu "$chat_id" ;;
        /tunnel) delete_last_message "$chat_id"; show_tunnel_menu "$chat_id" ;;
        /interface) delete_last_message "$chat_id"; show_interface_menu "$chat_id" ;;
        /services) delete_last_message "$chat_id"; show_services_menu "$chat_id" ;;
        /ttl) delete_last_message "$chat_id"; show_ttl_menu "$chat_id" ;;
        /crontab) delete_last_message "$chat_id"; show_cron_menu "$chat_id" ;;
        /theme) delete_last_message "$chat_id"; show_theme_menu "$chat_id" ;;
        /about) delete_last_message "$chat_id"; show_about_menu "$chat_id" ;;
        /help) delete_last_message "$chat_id"; send_message "XIDZs Bot Help\n/start - Main menu\n/menu - Main menu\n/clear - Clear cache\n/packages - Packages Manager\n/tools - System Tools\n/vnstat - vnstat monitoring\n/wifi - WiFi settings\n/ttl - Modify TTL\n/crontab - Cron Manager\n/theme - Theme Manager\n/about - About Bot" "$chat_id" ;;
        *) 
            if [ -n "$BOT_USERNAME_CUR" ] && [[ "$text" == *"@${BOT_USERNAME_CUR}"* ]]; then
                delete_last_message "$chat_id"
                show_main_menu "$chat_id"
            else
                delete_last_message "$chat_id"
                send_message "✘ Unknown command." "$chat_id"
            fi
            ;;
    esac
}
