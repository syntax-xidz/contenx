show_wifi_menu() {
    local chat_id="$1"
    local wifi_status="Unknown"
    local enabled_count=0
    local total_count=0
    local i=0
    while uci get wireless.@wifi-device[$i] >/dev/null 2>&1; do
        total_count=$((total_count+1))
        local disabled=$(uci -q get wireless.@wifi-device[$i].disabled)
        if [ -z "$disabled" ] || [ "$disabled" = "0" ]; then enabled_count=$((enabled_count + 1)); fi
        i=$((i+1))
    done

    if [ "$enabled_count" -gt 0 ]; then
        local details=""
        local j=0
        while uci get wireless.@wifi-iface[$j] >/dev/null 2>&1; do
            local iface_disabled=$(uci -q get wireless.@wifi-iface[$j].disabled)
            local dev=$(uci -q get wireless.@wifi-iface[$j].device)
            local dev_disabled="0"
            [ -n "$dev" ] && dev_disabled=$(uci -q get wireless.$dev.disabled)
            
            if [ "$iface_disabled" != "1" ] && [ "$dev_disabled" != "1" ]; then
                local ssid=$(uci -q get wireless.@wifi-iface[$j].ssid)
                local enc=$(uci -q get wireless.@wifi-iface[$j].encryption)
                local ch=$(uci -q get wireless.$dev.channel)
                local ht=$(uci -q get wireless.$dev.htmode)
                
                local mode=""
                if [[ "$ht" =~ ([0-9]+) ]]; then
                    mode="${BASH_REMATCH[1]}MHZ"
                else
                    mode="$ht"
                fi
                
                local key_disp=""
                case "$enc" in
                    *psk-mixed*|*psk+psk2*) key_disp="WPA/WPA2/PERSONAL" ;;
                    *psk2+ccmp*|*psk2*) key_disp="WPA2/PERSONAL" ;;
                    *sae-mixed*) key_disp="WPA2/WPA3/PERSONAL" ;;
                    *sae*) key_disp="WPA3/PERSONAL" ;;
                    *psk*) key_disp="WPA/PERSONAL" ;;
                    none) key_disp="NONE" ;;
                    *) key_disp=$(echo "$enc" | tr '[:lower:]' '[:upper:]') ;;
                esac
                
                [ -n "$details" ] && details="${details}\n\n"
                details="${details}SSID: ${ssid}\nCH: ${ch:-Auto}\nMODE: ${mode:-Auto}\nKEY: ${key_disp}"
            fi
            j=$((j+1))
        done
        
        if [ -n "$details" ]; then
            details=$(escape_html "$details")
            wifi_status="✔ Enabled (${enabled_count}/${total_count})\n${details}"
        else
            wifi_status="✔ Enabled (${enabled_count}/${total_count})\nNo Active SSID"
        fi
    else
        wifi_status="✘ Disabled"
    fi

    local keyboard=$(build_keyboard WIFI_MENU 3 true)
    send_keyboard_menu "WiFi Control\nStatus: ${wifi_status}" "$chat_id" "$keyboard"
}
