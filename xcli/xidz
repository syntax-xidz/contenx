            wifi reload >/dev/null 2>&1 &
            local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back\",\"callback_data\":\"w_ch_sel\"}]]"
            send_keyboard_menu "✔ Channel for $r changed to: $val\nApplying changes..." "$chat_id" "$kb"
            ;;
        w_mo_v_*)
            local data=${cb#w_mo_v_}
            local r=$(echo "$data" | cut -d'_' -f1)
            local val=$(echo "$data" | cut -d'_' -f2-)
            uci set wireless.$r.htmode="$val"
            uci commit wireless
            wifi reload >/dev/null 2>&1 &
            local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back\",\"callback_data\":\"w_mo_sel\"}]]"
            send_keyboard_menu "✔ HT Mode for $r changed to: $val\nApplying changes..." "$chat_id" "$kb"
            ;;
        w_se_v_*)
            local data=${cb#w_se_v_}
            local i=$(echo "$data" | cut -d'_' -f1)
            local val=$(echo "$data" | cut -d'_' -f2-)
            if [ "$val" != "none" ]; then
                local cur_key=$(uci -q get wireless.@wifi-iface[$i].key)
                if [ -z "$cur_key" ]; then
                    echo "WAIT_WIFI_SEC_PASS:${i}|${val}" > "$state_file"
                    local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Cancel\",\"callback_data\":\"w_se_sel\"}]]"
                    send_keyboard_menu "You selected <b>${val}</b> but no password exists.\n\nSend a new WiFi Password (min 8 chars) to apply this security mode:" "$chat_id" "$kb"
                    return
                fi
            fi
            uci set wireless.@wifi-iface[$i].encryption="$val"
            if [ "$val" = "none" ]; then
                uci delete wireless.@wifi-iface[$i].key 2>/dev/null
            fi
            uci commit wireless
            wifi reload >/dev/null 2>&1 &
            local ssid=$(uci -q get wireless.@wifi-iface[$i].ssid)
            local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back\",\"callback_data\":\"w_se_sel\"}]]"
            send_keyboard_menu "✔ Security for $ssid changed to: $val\nApplying changes..." "$chat_id" "$kb"
            ;;
        "iface_add")
            echo "WAIT_IFACE_ADD_NAME" > "$state_file"
            local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Cancel\",\"callback_data\":\"interface\"}]]"
            send_keyboard_menu "Send New Interface Name (e.g., tethering, wan2):" "$chat_id" "$kb"
            ;;
        "iface_rm_menu")
            local ifaces=$(uci show network 2>/dev/null | grep "=interface" | cut -d. -f2 | cut -d= -f1)
            local kb="["
            local row="["
            local col=0
            for iface in $ifaces; do
                if [[ "$iface" =~ ^(loopback|lan|br-lan|eth0|phy0)$ ]]; then continue; fi
                [ $col -gt 0 ] && row="${row},"
                row="${row}{\"text\":\"${iface}\",\"callback_data\":\"i_rm_${iface}\"}"
                col=$((col+1))
                if [ $col -eq 3 ]; then kb="${kb}${row}],"; row="["; col=0; fi
            done
            if [ $col -gt 0 ]; then kb="${kb}${row}],"; fi
            kb="${kb}[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back\",\"callback_data\":\"interface\"}]]"
            send_keyboard_menu "Select Interface to Remove:" "$chat_id" "$kb"
            ;;
        i_rm_*)
            local iface=${cb#i_rm_}
            uci delete network.$iface 2>/dev/null
            uci commit network
            /etc/init.d/network restart >/dev/null 2>&1 &
            local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back\",\"callback_data\":\"interface\"}]]"
            send_keyboard_menu "✔ Interface $iface removed.\nNetwork is restarting..." "$chat_id" "$kb"
            ;;
        i_add_p_*)
            local proto=${cb#i_add_p_}
            local iname=$(cat "/tmp/xidz_iface_add_${chat_id}.txt" 2>/dev/null)
            echo "${iname}|${proto}" > "/tmp/xidz_iface_add_${chat_id}.txt"
            local devs=$(ls -1 /sys/class/net/ 2>/dev/null | grep -vE '^(lo|ifb|teql|erspan|gre|ip_vti|ip6|sit)' | xargs)
            local kb="["
            local row="["
            local col=0
            for dev in $devs; do
                [ $col -gt 0 ] && row="${row},"
                row="${row}{\"text\":\"${dev}\",\"callback_data\":\"i_add_d_${dev}\"}"
                col=$((col+1))
                if [ $col -eq 3 ]; then kb="${kb}${row}],"; row="["; col=0; fi
            done
            if [ $col -gt 0 ]; then kb="${kb}${row}],"; fi
            kb="${kb}[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Cancel\",\"callback_data\":\"interface\"}]]"
            send_keyboard_menu "Interface: <b>$iname</b>\nProtocol: <b>$proto</b>\n\nSelect Physical Device:" "$chat_id" "$kb"
            ;;
        i_add_d_*)
            local dev=${cb#i_add_d_}
            local state_data=$(cat "/tmp/xidz_iface_add_${chat_id}.txt" 2>/dev/null)
            echo "${state_data}|${dev}" > "/tmp/xidz_iface_add_${chat_id}.txt"
            local iname=$(echo "$state_data" | cut -d'|' -f1)
            local proto=$(echo "$state_data" | cut -d'|' -f2)
            local zones=$(uci show firewall 2>/dev/null | grep "=zone" | cut -d. -f2 | cut -d= -f1)
            local kb="["
            local row="["
            local col=0
            for z in $zones; do
                local zname=$(uci -q get firewall.$z.name)
                [ -z "$zname" ] && zname="$z"
                [ $col -gt 0 ] && row="${row},"
                row="${row}{\"text\":\"${zname}\",\"callback_data\":\"i_add_z_${zname}\"}"
                col=$((col+1))
                if [ $col -eq 3 ]; then kb="${kb}${row}],"; row="["; col=0; fi
            done
            if [ $col -gt 0 ]; then kb="${kb}${row}],"; fi
            kb="${kb}[{\"text\":\"None / Skip\",\"callback_data\":\"i_add_z_none\"}],"
            kb="${kb}[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Cancel\",\"callback_data\":\"interface\"}]]"
            send_keyboard_menu "Interface: <b>$iname</b>\nProtocol: <b>$proto</b>\nDevice: <b>$dev</b>\n\nSelect Firewall Zone:" "$chat_id" "$kb"
            ;;
        i_add_z_*)
            local zone_name=${cb#i_add_z_}
            local state_data=$(cat "/tmp/xidz_iface_add_${chat_id}.txt" 2>/dev/null)
            rm -f "/tmp/xidz_iface_add_${chat_id}.txt"
            local iname=$(echo "$state_data" | cut -d'|' -f1)
            local proto=$(echo "$state_data" | cut -d'|' -f2)
            local dev=$(echo "$state_data" | cut -d'|' -f3)

            uci set network.$iname=interface
            uci set network.$iname.proto="$proto"
            uci set network.$iname.device="$dev"
            uci commit network

            if [ "$zone_name" != "none" ]; then
                local zones=$(uci show firewall 2>/dev/null | grep "=zone" | cut -d. -f2 | cut -d= -f1)
                for z in $zones; do
                    local n=$(uci -q get firewall.$z.name)
                    if [ "$n" = "$zone_name" ]; then
                        local cur_net=$(uci -q get firewall.$z.network)
                        if [ -n "$cur_net" ]; then
                            if ! echo "$cur_net" | grep -qw "$iname"; then
                                uci set firewall.$z.network="$cur_net $iname"
                            fi
                        else
                            uci set firewall.$z.network="$iname"
                        fi
                        uci commit firewall
                        break
                    fi
                done
            fi

            /etc/init.d/network restart >/dev/null 2>&1 &
            /etc/init.d/firewall restart >/dev/null 2>&1 &
            
            local kb="[[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back\",\"callback_data\":\"interface\"}]]"
            send_keyboard_menu "✔ Interface <b>$iname</b> added successfully!\n\nProtocol: $proto\nDevice: $dev\nFirewall Zone: $zone_name\n\nApplying changes..." "$chat_id" "$kb"
            ;;
        t_pg_*) local s=$(echo "$cb" | cut -d'_' -f3); local p=$(echo "$cb" | cut -d'_' -f4); tunnel_show_groups "$s" "$p" "$chat_id" ;;
        t_g_*) local s=$(echo "$cb" | cut -d'_' -f3); local i=$(echo "$cb" | cut -d'_' -f4); tunnel_show_proxies "$s" "$i" "1" "$chat_id" ;;
        t_pp_*) local s=$(echo "$cb" | cut -d'_' -f3); local p=$(echo "$cb" | cut -d'_' -f4); tunnel_show_proxies "$s" "" "$p" "$chat_id" ;;
        t_s_*) local s=$(echo "$cb" | cut -d'_' -f3); local i=$(echo "$cb" | cut -d'_' -f4); local p=$(echo "$cb" | cut -d'_' -f5); tunnel_set_proxy "$s" "$i" "$p" "$chat_id" ;;
        "ignore") ;;
        tunnel_select_*) show_tunnel_action_menu "$(echo "$cb" | sed 's/tunnel_select_//' | awk '{for(i=1;i<=NF;i++){$i=toupper(substr($i,1,1))substr($i,2)}}1')" "$chat_id" ;;
        tunnel_reload_*) tunnel_service_action "reload" "$(echo "$cb" | sed 's/tunnel_reload_//')" "$chat_id" ;;
        tunnel_restart_*) tunnel_service_action "restart" "$(echo "$cb" | sed 's/tunnel_restart_//')" "$chat_id" ;;
        tunnel_stop_*) tunnel_service_action "stop" "$(echo "$cb" | sed 's/tunnel_stop_//')" "$chat_id" ;;
        tunnel_status_*) tunnel_service_action "status" "$(echo "$cb" | sed 's/tunnel_status_//')" "$chat_id" ;;
        iface_select_*) show_interface_action_menu "$(echo "$cb" | sed 's/iface_select_//')" "$chat_id" ;;
        iface_restart_*) restart_interface "$(echo "$cb" | sed 's/iface_restart_//')" "$chat_id" ;;
        iface_reload_*) reload_interface "$(echo "$cb" | sed 's/iface_reload_//')" "$chat_id" ;;
        iface_down_*) interface_down "$(echo "$cb" | sed 's/iface_down_//')" "$chat_id" ;;
        iface_up_*) interface_up "$(echo "$cb" | sed 's/iface_up_//')" "$chat_id" ;;
        "reboot") confirm_reboot "$chat_id" ;;
        "poweroff") confirm_poweroff "$chat_id" ;;
        "confirm_reboot_yes") delete_last_message "$chat_id"; send_message "✔ Rebooting..." "$chat_id"; sleep 2; reboot ;;
        "confirm_poweroff_yes") delete_last_message "$chat_id"; send_message "✔ Powering OFF..." "$chat_id"; sleep 2; poweroff ;;
    esac
}
poll_bot() {
    local token="$1"
    local offset_file="${OFFSET_FILE}_${token//:/_}"
    local last_offset=0
    if [ -f "$offset_file" ]; then last_offset=$(cat "$offset_file"); fi
    local bot_info=$(curl -s -X GET "https://api.telegram.org/bot${token}/getMe")
    local bot_username=$(echo "$bot_info" | grep -o '"username":"[^"]*"' | head -1 | cut -d'"' -f4)
    local wib=$(TZ="Asia/Jakarta" date '+%H:%M:%S')
    local init_auth=$(grep "^ALLOWED_CHAT_IDS=" /usr/bin/xidz | head -n 1 | cut -d'"' -f2 | tr ',.' ' ' | xargs)
    local init_grp=$(grep "^ALLOWED_GROUP_IDS=" /usr/bin/xidz | head -n 1 | cut -d'"' -f2 | tr ',.' ' ' | xargs)
    local gm=$(grep "^GROUP_MODE=" /usr/bin/xidz | head -n 1 | cut -d'"' -f2)
    local all_notify="$init_auth"
    [ "$gm" = "1" ] && all_notify="$init_auth $init_grp"
    for cid in $all_notify; do
        if [[ "$cid" =~ ^-?[0-9]+$ ]]; then
            local json_payload=$(jq -n --arg cid "$cid" --arg text "$(echo -e "XIDZs Bot Started\n\n✔ System Ready\nWIB: $wib\n\nType /start or @${bot_username} to open menu.")" '{chat_id: $cid, text: $text, parse_mode: "HTML"}')
            curl -s -X POST "https://api.telegram.org/bot${token}/sendMessage" -H "Content-Type: application/json" -d "$json_payload" >/dev/null
        fi
    done
    while true; do
        local updates=$(curl $CURL_RESOLVE -s -X GET "https://api.telegram.org/bot${token}/getUpdates?offset=$((last_offset + 1))&timeout=30")
        if [[ -z "$updates" || "$updates" == *"\"result\":[]"* ]]; then
            sleep 1
            continue
        fi
        local ids=$(echo "$updates" | grep -o '"update_id":[0-9]*' | grep -o '[0-9]*')
        for uid in $ids; do
            if [ "$uid" -le "$last_offset" ]; then continue; fi
            echo "$uid" > "$offset_file"
            last_offset="$uid"
            local update_data=$(echo "$updates" | grep -A 50 "\"update_id\":$uid")
            export START_UPTIME=$(cut -d' ' -f1 /proc/uptime)
            local msg_date=""
            [[ "$update_data" =~ \"date\":([0-9]+) ]] && msg_date="${BASH_REMATCH[1]}"
            export MSG_DATE_CUR="$msg_date"
            local chat_id=""
            [[ "$update_data" =~ \"chat\":\{\"id\":([0-9-]+) ]] && chat_id="${BASH_REMATCH[1]}"
            local chat_type=""
            [[ "$update_data" =~ \"chat\":\{[^\}]*\"type\":\"([^\"]+)\" ]] && chat_type="${BASH_REMATCH[1]}"
            local chat_title=""
            [[ "$update_data" =~ \"chat\":\{[^\}]*\"title\":\"([^\"]+)\" ]] && chat_title="${BASH_REMATCH[1]}"
            local chat_uname=""
            [[ "$update_data" =~ \"chat\":\{[^\}]*\"username\":\"([^\"]+)\" ]] && chat_uname="${BASH_REMATCH[1]}"
            local from_id=""
            [[ "$update_data" =~ \"from\":\{\"id\":([0-9-]+) ]] && from_id="${BASH_REMATCH[1]}"
            local from_username=""
            [[ "$update_data" =~ \"from\":\{[^\}]*\"username\":\"([^\"]+)\" ]] && from_username="${BASH_REMATCH[1]}"
            local thread_id=""
            [[ "$update_data" =~ \"message_thread_id\":([0-9]+) ]] && thread_id="${BASH_REMATCH[1]}"
            local dynamic_auth=$(grep "^ALLOWED_CHAT_IDS=" /usr/bin/xidz | head -n 1 | cut -d'"' -f2 | tr ',.' ' ' | xargs)
            local dynamic_group_auth=$(grep "^ALLOWED_GROUP_IDS=" /usr/bin/xidz | head -n 1 | cut -d'"' -f2 | tr ',.' ' ' | xargs)
            local dynamic_group_mode=$(grep "^GROUP_MODE=" /usr/bin/xidz | head -n 1 | cut -d'"' -f2)
            local auth_list=" $dynamic_auth "
            local group_auth_list=" $dynamic_group_auth "
            local is_auth_user=0
            local is_auth_chat=0
            if echo "$auth_list" | grep -iq " $from_id "; then is_auth_user=1; fi
            if [ -n "$from_username" ]; then
                if echo "$auth_list" | grep -iq " $from_username "; then is_auth_user=1; fi
                if echo "$auth_list" | grep -iq " @$from_username "; then is_auth_user=1; fi
            fi
            if [ "$chat_type" = "private" ]; then
                is_auth_chat=1
            else
                if [ "$dynamic_group_mode" = "1" ]; then
                    if echo "$group_auth_list $auth_list" | grep -iq " $chat_id "; then is_auth_chat=1; fi
                    if [ -n "$chat_title" ]; then
                        if echo "$group_auth_list $auth_list" | grep -iq " $chat_title "; then is_auth_chat=1; fi
                    fi
                    if [ -n "$chat_uname" ]; then
                        if echo "$group_auth_list $auth_list" | grep -iq " @$chat_uname "; then is_auth_chat=1; fi
                        if echo "$group_auth_list $auth_list" | grep -iq " $chat_uname "; then is_auth_chat=1; fi
                    fi
                fi
            fi
            if [ "$is_auth_user" -eq 1 ] && [ "$is_auth_chat" -eq 1 ]; then
                export BOT_TOKEN_CUR="$token"
                export API_URL="https://api.telegram.org/bot${BOT_TOKEN_CUR}"
                export BOT_USERNAME_CUR="$bot_username"
                export MESSAGE_THREAD_ID_CUR="$thread_id"
                if [[ "$update_data" =~ \"callback_query\" ]]; then
                    local cb_id=""
                    [[ "$update_data" =~ \"id\":\"([0-9]+)\" ]] && cb_id="${BASH_REMATCH[1]}"
                    local cb_data=""
                    [[ "$update_data" =~ \"data\":\"([^\"]+)\" ]] && cb_data="${BASH_REMATCH[1]}"
                    if [ -n "$cb_data" ] && [ -n "$cb_id" ]; then handle_callback "$cb_data" "$cb_id" "$chat_id"; fi
                elif [[ "$update_data" =~ \"document\"|\"photo\"|\"video\"|\"audio\" ]]; then
                    local file_id=""
                    local file_name=""
                    if [[ "$update_data" =~ \"document\" ]]; then
                        [[ "$update_data" =~ \"file_id\":\"([^\"]+)\" ]] && file_id="${BASH_REMATCH[1]}"
                        [[ "$update_data" =~ \"file_name\":\"([^\"]+)\" ]] && file_name="${BASH_REMATCH[1]}"
                    elif [[ "$update_data" =~ \"photo\" ]]; then
                        file_id=$(echo "$update_data" | grep -o '"file_id":"[^"]*"' | tail -1 | cut -d'"' -f4)
                        file_name="photo_${uid}.jpg"
                    elif [[ "$update_data" =~ \"video\" ]]; then
                        [[ "$update_data" =~ \"file_id\":\"([^\"]+)\" ]] && file_id="${BASH_REMATCH[1]}"
                        [[ "$update_data" =~ \"file_name\":\"([^\"]+)\" ]] && file_name="${BASH_REMATCH[1]}"
                        [ -z "$file_name" ] && file_name="video_${uid}.mp4"
                    elif [[ "$update_data" =~ \"audio\" ]]; then
                        [[ "$update_data" =~ \"file_id\":\"([^\"]+)\" ]] && file_id="${BASH_REMATCH[1]}"
                        [[ "$update_data" =~ \"file_name\":\"([^\"]+)\" ]] && file_name="${BASH_REMATCH[1]}"
                        [ -z "$file_name" ] && file_name="audio_${uid}.mp3"
                    fi
                    if [ -n "$file_id" ]; then
                        handle_command_or_file "$chat_id" "" "$file_id" "$file_name"
                    fi
                elif [[ "$update_data" =~ \"message\" ]]; then
                    local text=""
                    [[ "$update_data" =~ \"text\":\"([^\"]+)\" ]] && text="${BASH_REMATCH[1]}"
                    if [ -n "$text" ]; then handle_command_or_file "$chat_id" "$text" "" ""; fi
                fi
            fi
        done
    done
}
main() {
    log_message "XIDZs Bot Started"
    local TG_IP=$(ping -c 1 -W 1 api.telegram.org 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' | head -n 1)
    [ -z "$TG_IP" ] && TG_IP="149.154.167.220"
    export CURL_RESOLVE="--resolve api.telegram.org:443:$TG_IP"
    export CHAT_IDS=$(echo "$ALLOWED_CHAT_IDS" | tr ',.' ' ' | xargs)
    export TOKENS=$(echo "$BOT_TOKENS" | tr ',.' ' ' | xargs)
    for token in $TOKENS; do
        poll_bot "$token" &
    done
    wait
}
cleanup() {
    log_message "XIDZs Bot Stopped"
    export CHAT_IDS=$(grep "^ALLOWED_CHAT_IDS=" /usr/bin/xidz | head -n 1 | cut -d'"' -f2 | tr ',.' ' ' | xargs)
    export GRP_IDS=$(grep "^ALLOWED_GROUP_IDS=" /usr/bin/xidz | head -n 1 | cut -d'"' -f2 | tr ',.' ' ' | xargs)
    local gm=$(grep "^GROUP_MODE=" /usr/bin/xidz | head -n 1 | cut -d'"' -f2)
    local all_notify="$CHAT_IDS"
    [ "$gm" = "1" ] && all_notify="$CHAT_IDS $GRP_IDS"
    export TOKENS=$(echo "$BOT_TOKENS" | tr ',.$' ' ')
    for token in $TOKENS; do
        local URL="https://api.telegram.org/bot${token}"
        for cid in $all_notify; do
            if [[ "$cid" =~ ^-?[0-9]+$ ]]; then
                local json_payload=$(jq -n --arg cid "$cid" --arg text "✘ Bot Stopped" '{chat_id: $cid, text: $text, parse_mode: "HTML"}')
                curl $CURL_RESOLVE -s -X POST "${URL}/sendMessage" -H "Content-Type: application/json" -d "$json_payload" >/dev/null
            fi
        done
    done
    kill $(jobs -p) 2>/dev/null
    exit 0
}
trap cleanup SIGTERM SIGINT
if ! command -v curl >/dev/null 2>&1 || ! command -v jq >/dev/null 2>&1; then exit 1; fi
touch "$LOG_FILE"
main
