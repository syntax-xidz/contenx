view_wifi_users() {
    local chat_id="$1"
    local out="Connected Devices:\n"
    local count=0
    if command -v iw >/dev/null 2>&1; then
        for iface in $(iw dev 2>/dev/null | awk '$1=="Interface"{print $2}'); do
            local stations=$(iw dev "$iface" station dump 2>/dev/null)
            if [ -n "$stations" ]; then
                local macs=$(echo "$stations" | grep "^Station" | awk '{print $2}')
                for mac in $macs; do
                    local st_data=$(echo "$stations" | awk -v m="$mac" '$0 ~ "Station " m {f=1; next} f && $0 ~ "Station" {f=0} f')
                    local rx=$(echo "$st_data" | grep "rx bytes:" | awk '{print $3}')
                    local tx=$(echo "$st_data" | grep "tx bytes:" | awk '{print $3}')
                    local ctime=$(echo "$st_data" | grep "connected time:" | awk '{print $3}')
                    [ -z "$rx" ] && rx=0
                    [ -z "$tx" ] && tx=0
                    [ -z "$ctime" ] && ctime=0
                    local total_mb=$(awk -v r="$rx" -v t="$tx" 'BEGIN {printf "%.2f", (r+t)/1048576}')
                    local h_time=$((ctime / 3600))
                    local m_time=$(((ctime % 3600) / 60))
                    local s_time=$((ctime % 60))
                    local uptime_str=$(printf "%02d:%02d:%02d" $h_time $m_time $s_time)
                    local hostname=$(awk -v m="$(echo "$mac" | tr 'A-Z' 'a-z')" 'tolower($2)==m {print $4; exit}' /tmp/dhcp.leases 2>/dev/null)
                    [ -z "$hostname" ] || [ "$hostname" = "*" ] && hostname="Unknown"
                    hostname=$(escape_html "$hostname")
                    out="${out}\n- ${hostname} (${mac})\n  Time: ${uptime_str} | Data: ${total_mb} MB"
                    count=$((count+1))
                done
            fi
        done
    fi
    if [ "$count" -eq 0 ]; then
        if [ -f "/tmp/dhcp.leases" ]; then
