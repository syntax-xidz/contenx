    kb="${kb}[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back\",\"callback_data\":\"back\"}]]"
    send_keyboard_menu "Theme Manager\n\nSelect theme to apply:" "$chat_id" "$kb"
}
