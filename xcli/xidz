        send_keyboard_menu "✔ ${t} ${act}ed." "$chat_id" "$kb"
    fi
}
tunnel_api_call() {
    local svc="$1"
    local endpoint="$2"
    local method="${3:-GET}"
    local data="$4"
    local secret=$(cat /etc/xidzs_api_secret_${svc}.txt 2>/dev/null)
    
    if [ -n "$secret" ] && [ -n "$data" ]; then
        curl -s -m 2 -X "$method" -H "Authorization: Bearer $secret" -H "Content-Type: application/json" -d "$data" "http://127.0.0.1:9090${endpoint}"
    elif [ -n "$secret" ]; then
        curl -s -m 2 -X "$method" -H "Authorization: Bearer $secret" "http://127.0.0.1:9090${endpoint}"
    elif [ -n "$data" ]; then
        curl -s -m 2 -X "$method" -H "Content-Type: application/json" -d "$data" "http://127.0.0.1:9090${endpoint}"
    else
        curl -s -m 2 -X "$method" "http://127.0.0.1:9090${endpoint}"
    fi
}
show_tunnel_dashboard() {
