show_ttl_menu() {
    local chat_id="$1"
    local val=$(nft list chain inet fw4 mangle_postrouting_ttl67 2>/dev/null | grep -o 'ip ttl set [0-9]*' | grep -o '[0-9]*' | head -n 1)
    [ -z "$val" ] && val=$(cat /etc/xidzs_ttl.txt 2>/dev/null || echo "65")
