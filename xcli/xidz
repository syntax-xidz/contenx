escape_html() { echo "$1" | sed 's/&/\&amp;/g; s/</\&lt;/g; s/>/\&gt;/g'; }
log_message() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"; }
send_message() {
    local message="$1"
    local default_id=$(grep "^ALLOWED_CHAT_IDS=" /usr/bin/xidz | head -n 1 | cut -d'"' -f2 | awk '{print $1}')
    local chat_id="${2:-$default_id}"
    local json_payload
    local end_uptime=$(cut -d' ' -f1 /proc/uptime)
    local d_time=$(awk "BEGIN { printf \"%.2f\", $end_uptime - ${START_UPTIME:-$end_uptime} }")
    local p_val=$(ping -c 1 -W 1 8.8.8.8 2>/dev/null | sed -n 's/.*time=\([0-9.]*\).*/\1/p')
    if [ -n "$p_val" ]; then p_val=$(awk "BEGIN {printf \"%.2f\", $p_val}"); else p_val="0.00"; fi
    message="${message}\n\nProses ${d_time}s | ${p_val}ms"
    if [ -n "$MESSAGE_THREAD_ID_CUR" ]; then
        json_payload=$(jq -n --arg cid "$chat_id" --arg tid "$MESSAGE_THREAD_ID_CUR" --arg text "$(echo -e "$message")" '{chat_id: $cid, message_thread_id: ($tid|tonumber), text: $text, parse_mode: "HTML"}')
    else
        json_payload=$(jq -n --arg cid "$chat_id" --arg text "$(echo -e "$message")" '{chat_id: $cid, text: $text, parse_mode: "HTML"}')
    fi
    local response=$(curl $CURL_RESOLVE -s -X POST "${API_URL}/sendMessage" -H "Content-Type: application/json" -d "$json_payload")
    local msg_id=$(echo "$response" | grep -o '"message_id":[0-9]*' | cut -d':' -f2)
    local thread_suffix=""; [ -n "$MESSAGE_THREAD_ID_CUR" ] && thread_suffix="_${MESSAGE_THREAD_ID_CUR}"
    [ -n "$msg_id" ] && echo "$msg_id" > "/tmp/xidz_lastmsg_${chat_id}${thread_suffix}_${BOT_TOKEN_CUR//:/_}"
}
delete_last_message() {
    local chat_id="$1"
    local thread_suffix=""; [ -n "$MESSAGE_THREAD_ID_CUR" ] && thread_suffix="_${MESSAGE_THREAD_ID_CUR}"
    local msg_file="/tmp/xidz_lastmsg_${chat_id}${thread_suffix}_${BOT_TOKEN_CUR//:/_}"
    if [ -f "$msg_file" ]; then
        local last_id=$(cat "$msg_file")
        if [ -n "$last_id" ]; then
            curl $CURL_RESOLVE -s -X POST "${API_URL}/deleteMessage" -H "Content-Type: application/json" -d "{\"chat_id\":\"${chat_id}\",\"message_id\":${last_id}}" > /dev/null 2>&1 &
        fi
        rm -f "$msg_file"
    fi
}
build_keyboard() {
    local -n menu_array=$1
    local columns=${2:-3}
    local add_back=${3:-true}
    local keyboard="["
    local count=0
    local row="["
    for key in "${!menu_array[@]}"; do
        local value="${menu_array[$key]}"
        if [ $count -gt 0 ]; then row="${row},"; fi
        row="${row}{\"text\":\"${key}\",\"callback_data\":\"${value}\"}"
        count=$((count + 1))
        if [ $count -eq $columns ]; then
            keyboard="${keyboard}${row}],"
            row="["
            count=0
        fi
    done
    if [ $count -gt 0 ]; then keyboard="${keyboard}${row}],"; fi
    if [ "$add_back" = true ]; then keyboard="${keyboard}[{\"text\":\"Home\",\"callback_data\":\"home\"},{\"text\":\"Back\",\"callback_data\":\"back\"}]"; else keyboard="${keyboard:0:-1}"; fi
    keyboard="${keyboard}]"
    echo "$keyboard"
}
send_keyboard_menu() {
    local message="$1"
    local chat_id="$2"
    local keyboard="$3"
    local json_payload
    local end_uptime=$(cut -d' ' -f1 /proc/uptime)
    local d_time=$(awk "BEGIN { printf \"%.2f\", $end_uptime - ${START_UPTIME:-$end_uptime} }")
    local p_val=$(ping -c 1 -W 1 8.8.8.8 2>/dev/null | sed -n 's/.*time=\([0-9.]*\).*/\1/p')
    if [ -n "$p_val" ]; then p_val=$(awk "BEGIN {printf \"%.2f\", $p_val}"); else p_val="0.00"; fi
    message="${message}\n\nProses ${d_time}s | ${p_val}ms"
    if [ -n "$MESSAGE_THREAD_ID_CUR" ]; then
        json_payload=$(jq -n --arg cid "$chat_id" --arg tid "$MESSAGE_THREAD_ID_CUR" --arg text "$(echo -e "$message")" --argjson kb "$keyboard" '{chat_id: $cid, message_thread_id: ($tid|tonumber), text: $text, parse_mode: "HTML", reply_markup: {inline_keyboard: $kb}}')
    else
        json_payload=$(jq -n --arg cid "$chat_id" --arg text "$(echo -e "$message")" --argjson kb "$keyboard" '{chat_id: $cid, text: $text, parse_mode: "HTML", reply_markup: {inline_keyboard: $kb}}')
    fi
    local thread_suffix=""; [ -n "$MESSAGE_THREAD_ID_CUR" ] && thread_suffix="_${MESSAGE_THREAD_ID_CUR}"
    local msg_file="/tmp/xidz_lastmsg_${chat_id}${thread_suffix}_${BOT_TOKEN_CUR//:/_}"
    local last_id=""
    [ -f "$msg_file" ] && last_id=$(cat "$msg_file")
    local response
    local msg_id
    if [ -n "$last_id" ]; then
        local edit_payload=$(jq -n --arg cid "$chat_id" --arg mid "$last_id" --arg text "$(echo -e "$message")" --argjson kb "$keyboard" '{chat_id: $cid, message_id: ($mid|tonumber), text: $text, parse_mode: "HTML", reply_markup: {inline_keyboard: $kb}}')
        response=$(curl $CURL_RESOLVE -s -X POST "${API_URL}/editMessageText" -H "Content-Type: application/json" -d "$edit_payload")
        local ok=$(echo "$response" | grep -o '"ok":true')
        if [ -z "$ok" ]; then
            local is_not_mod=$(echo "$response" | grep -o 'message is not modified')
            if [ -z "$is_not_mod" ]; then
                response=$(curl $CURL_RESOLVE -s -X POST "${API_URL}/sendMessage" -H "Content-Type: application/json" -d "$json_payload")
                msg_id=$(echo "$response" | grep -o '"message_id":[0-9]*' | cut -d':' -f2)
                [ -n "$msg_id" ] && echo "$msg_id" > "$msg_file"
            fi
        fi
    else
        response=$(curl $CURL_RESOLVE -s -X POST "${API_URL}/sendMessage" -H "Content-Type: application/json" -d "$json_payload")
        msg_id=$(echo "$response" | grep -o '"message_id":[0-9]*' | cut -d':' -f2)
        [ -n "$msg_id" ] && echo "$msg_id" > "$msg_file"
    fi
}
answer_callback() { curl $CURL_RESOLVE -s -X POST "${API_URL}/answerCallbackQuery" -d "callback_query_id=$1" > /dev/null 2>&1 & }
uptime_str() {
    local u=$(cut -d. -f1 /proc/uptime)
    local d=$((u/86400))
    local h=$((u%86400/3600))
    local m=$((u%3600/60))
    local s=$((u%60))
    local result=""
    [ $d -gt 0 ] && result="${d}d "
    result="${result}$(printf "%02d:%02d:%02d" $h $m $s)"
    echo "$result"
}
get_cpu_temp() { if [ -f /sys/class/thermal/thermal_zone0/temp ]; then awk '{printf("%.1fC", $1/1000)}' /sys/class/thermal/thermal_zone0/temp; else echo ""; fi; }
get_cpu_freq() { if [ -f /sys/devices/system/cpu/cpu0/cpufreq/scaling_cur_freq ]; then awk '{printf("%.0f MHz", $1/1000)}' /sys/devices/system/cpu/cpu0/cpufreq/scaling_cur_freq; else echo ""; fi; }
get_public_ip_info() {
    local ip_info=$(curl -s --max-time 5 "http://ip-api.com/json/" 2>/dev/null)
    if [ -z "$ip_info" ]; then echo "Unknown|Unknown|Unknown|Unknown|Unknown|Unknown"; return; fi
    local ip=$(echo "$ip_info" | grep -o '"query":"[^"]*"' | cut -d'"' -f4)
    local country=$(echo "$ip_info" | grep -o '"country":"[^"]*"' | cut -d'"' -f4)
    local city=$(echo "$ip_info" | grep -o '"city":"[^"]*"' | cut -d'"' -f4)
    local isp=$(echo "$ip_info" | grep -o '"isp":"[^"]*"' | cut -d'"' -f4)
    local region=$(echo "$ip_info" | grep -o '"regionName":"[^"]*"' | cut -d'"' -f4)
    local region_code=$(echo "$ip_info" | grep -o '"region":"[^"]*"' | cut -d'"' -f4)
    [ -z "$ip" ] && ip="Unknown"
    [ -z "$country" ] && country="Unknown"
    [ -z "$city" ] && city="Unknown"
    [ -z "$isp" ] && isp="Unknown"
    [ -z "$region" ] && region="Unknown"
    [ -z "$region_code" ] && region_code="Unknown"
    echo "${ip}|${country}|${city}|${isp}|${region}|${region_code}"
}
show_main_menu() {
    local chat_id="$1"
    local keyboard=$(build_keyboard MAIN_MENU 4 false)
    local ip_info=$(get_public_ip_info)
    local ip=$(echo "$ip_info" | cut -d'|' -f1)
    local country=$(echo "$ip_info" | cut -d'|' -f2)
    local city=$(echo "$ip_info" | cut -d'|' -f3)
    local isp=$(echo "$ip_info" | cut -d'|' -f4)
    
    local ping_ms=$(ping -c 1 -W 2 8.8.8.8 2>/dev/null | sed -n 's/.*time=\([0-9.]*\).*/\1/p')
    if [ -n "$ping_ms" ]; then ping_ms=$(awk "BEGIN {printf \"%.3f\", $ping_ms}"); else ping_ms="N/A"; fi
    
    local hostname=$(cat /proc/sys/kernel/hostname 2>/dev/null)
    [ -z "$hostname" ] && hostname=$(uci -q get system.@system[0].hostname 2>/dev/null)
    [ -z "$hostname" ] && hostname="OpenWrt"
    
    local day_en=$(date +%A)
    local day_id="Senin"
    case "$day_en" in
        Monday) day_id="Senin";;
        Tuesday) day_id="Selasa";;
        Wednesday) day_id="Rabu";;
        Thursday) day_id="Kamis";;
        Friday) day_id="Jumat";;
        Saturday) day_id="Sabtu";;
        Sunday) day_id="Minggu";;
    esac
    local wib_str="$(date '+%H:%M') WIB | ${day_id} | $(date '+%d/%m/%Y')"
    
    local iface_stats=""
    if [ -d "/sys/class/net/br-lan" ]; then
        local rx=$(cat "/sys/class/net/br-lan/statistics/rx_bytes" 2>/dev/null || echo 0)
        local tx=$(cat "/sys/class/net/br-lan/statistics/tx_bytes" 2>/dev/null || echo 0)
        local total=$((rx + tx))
        local usage_str=""
        if [ "$total" -ge 1073741824 ]; then
            usage_str=$(awk "BEGIN {printf \"%.1f GB\", $total/1073741824}")
        else
            usage_str=$(awk "BEGIN {printf \"%.1f MB\", $total/1048576}")
        fi
        iface_stats="br-lan : ${usage_str}"
    fi

    for iface_path in /sys/class/net/*; do
        [ ! -d "$iface_path" ] && continue
        local iface=$(basename "$iface_path")
        if [[ "$iface" =~ ^(lo|ifb.*|teql.*|erspan.*|gre.*|ip_vti.*|ip6.*|sit.*|br-lan)$ ]]; then continue; fi
        local state=$(cat "$iface_path/operstate" 2>/dev/null || echo "unknown")
        local carrier=$(cat "$iface_path/carrier" 2>/dev/null || echo "0")
        if [ "$state" = "up" ] && [ "$carrier" = "1" ]; then
            local rx=$(cat "$iface_path/statistics/rx_bytes" 2>/dev/null || echo 0)
            local tx=$(cat "$iface_path/statistics/tx_bytes" 2>/dev/null || echo 0)
            local total=$((rx + tx))
            if [ "$total" -gt 0 ]; then
                local usage_str=""
                if [ "$total" -ge 1073741824 ]; then
                    usage_str=$(awk "BEGIN {printf \"%.1f GB\", $total/1073741824}")
                else
                    usage_str=$(awk "BEGIN {printf \"%.1f MB\", $total/1048576}")
                fi
                if [ -z "$iface_stats" ]; then
                    iface_stats="${iface} : ${usage_str}"
                else
                    iface_stats="${iface_stats} | ${iface} : ${usage_str}"
                fi
            fi
        fi
    done

    send_keyboard_menu "XIDZs Monitor\n\nHello ... ${hostname}\nPing: ${ping_ms} ms\nIP: <span class=\"tg-spoiler\">${ip}</span>\nISP: ${isp}\nLocation: ${city}, ${country}\nWaktu : ${wib_str}\n${iface_stats}\n\nSelect option:" "$chat_id" "$keyboard"
}
